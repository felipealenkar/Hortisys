unit Controller.TipoCultura;

interface

uses
  System.Generics.Collections,
  Model.TipoCultura,
  Service.TipoCultura;

type
  TTipoCulturaController = class
  private
    FTipoCulturaService: TTipoCulturaService;
  public
    constructor Create(PTipoCulturaService: TTipoCulturaService);
    destructor Destroy; override;
    procedure Inserir(PDescricao: string);
    procedure Atualizar(PId: Integer; PDescricao: string);
    procedure Excluir(PId: Integer);
    function Listar(POrdenacao: string): TObjectList<TTipoCultura>;
    function Pesquisar(PBusca, POrdenacao: string): TObjectList<TTipoCultura>;
  end;

implementation

constructor TTipoCulturaController.Create(PTipoCulturaService: TTipoCulturaService);
begin
  inherited Create;
  FTipoCulturaService := PTipoCulturaService;
end;

destructor TTipoCulturaController.Destroy;
begin
  FTipoCulturaService.Free;
  inherited;
end;

procedure TTipoCulturaController.Inserir(PDescricao: string);
begin
  FTipoCulturaService.Inserir(PDescricao);
end;

procedure TTipoCulturaController.Atualizar(PId: Integer; PDescricao: string);
var
  LTipoCultura: TTipoCultura;
begin
  LTipoCultura := TTipoCultura.Create;
  try
    LTipoCultura.IdTipoCultura := PId;
    LTipoCultura.Descricao := PDescricao;

    FTipoCulturaService.Atualizar(LTipoCultura);
  finally
    LTipoCultura.Free;
  end;

procedure TTipoCulturaController.Excluir(PId: Integer);
begin
  FTipoCulturaService.Excluir(PId);
end;

function TTipoCulturaController.Listar(POrdenacao: string): TObjectList<TTipoCultura>;
begin
  Result := FTipoCulturaService.Listar(POrdenacao);
end;

function TTipoCulturaController.Pesquisar(PBusca, POrdenacao: string): TObjectList<TTipoCultura>;
begin
  Result := FTipoCulturaService.Pesquisar(PBusca, POrdenacao);
end;

end.
