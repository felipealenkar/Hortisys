unit Repository.Manejo;

interface

uses
  Repository.Base,
  System.SysUtils,
  System.Generics.Collections,
  Data.DB, FireDAC.Comp.Client, FireDAC.Stan.Param,
  Model.Manejo,
  Model.DbStart;

type
  TManejoRepository = class(TBaseRepository)
  public
    procedure Inserir(PManejo: TManejo);
    procedure Atualizar(PManejo: TManejo);
    procedure Excluir(PIdManejo: Integer);

    function ObterPorId(PId: Integer): TManejo;

    function Listar(POrdenacao: string): TObjectList<TManejo>;
    function Pesquisar(PBusca, POrdenacao: string): TObjectList<TManejo>;

    function ListarPorCultura(PIdCultura: Integer): TObjectList<TManejo>; // HIST紑ICO
  end;

implementation

{ TManejoRepository }

procedure TManejoRepository.Atualizar(PManejo: TManejo);
var
  LQuery: TFDQuery;
  LConnection: TFDConnection;
begin
  LQuery := nil;
  LConnection := nil;
  try
    try
      LConnection := CriarConexao(TDBStart.NomeDatabase);
      LQuery := TFDQuery.Create(nil);
      LQuery.Connection := LConnection;
      LQuery.SQL.Text :=
      Format('UPDATE %s.manejo SET ' +
             'id_manejo = :PIdManejo, ' +
             'descricao = :PDescricao, ' +
             'id_tipomanejo=:PIdTipoManejo, ' +
             'id_cultura=:PIdCultura, ' +
             'data_manejo=:PDataManejo, ' +
             'quantidade=:PQuantidade, ' +
             'unidade=:PUnidade, ' +
             'observacao=:PObservacao ' +
             'WHERE id_manejo=:PIdManejo',
             [TDBStart.NomeSchema]);

      LQuery.ParamByName('PIdManejo').AsInteger := PManejo.IdManejo;
      LQuery.ParamByName('PDescricao').AsString := PManejo.Descricao;
      LQuery.ParamByName('PIdTipoManejo').AsInteger := PManejo.IdTipoManejo;
      LQuery.ParamByName('PIdCultura').AsInteger := PManejo.IdCultura;
      LQuery.ParamByName('PDataManejo').AsDateTime := PManejo.DataManejo;
      LQuery.ParamByName('PQuantidade').AsFloat := PManejo.Quantidade;
      LQuery.ParamByName('PUnidade').AsString := PManejo.Unidade;
      LQuery.ParamByName('PObservacao').AsString := PManejo.Obs;
      LQuery.ExecSQL;
    except
      on E:Exception do
        raise Exception.Create(
        Format('Erro ao atualizar dados na tabela %s.manejo',[TDBStart.NomeSchema]) +
        sLineBreak + sLineBreak + E.ToString);
    end;
  finally
    LQuery.Free;
    LConnection.Free;
  end;
end;

