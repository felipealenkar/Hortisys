unit Repository.TipoCultura;

interface

uses
  Repository.Base,
  System.SysUtils,
  System.Generics.Collections,
  Data.DB, FireDAC.Comp.Client, FireDAC.Stan.Param,
  Model.TipoCultura, Model.Cultura, Model.DbStart;

type
  TTipoCulturaRepository = class(TBaseRepository)
  private
  public
    function ObterPorId(PIdTipoCultura: Integer): TTipoCultura;
    procedure Atualizar(PTipoCultura: TTipoCultura);
    procedure Excluir(PIdTipoCultura: Integer);
    procedure Inserir(PTipoCultura: TTipoCultura);
    function Listar(POrdenacao: string): TObjectList<TTipoCultura>;
    function Pesquisar(PBusca, PORdenacao: string): TObjectList<TTipoCultura>;
    function ExisteDescricao(PDescricao: string; PIdIgnorar: Integer = 0): Boolean;
    function ExisteNaTabelaCultura(PIdTipoCultura: Integer): Boolean;
    function ListarCulturasVinculadas(PId_TipoCultura: Integer): TObjectList<TCultura>;
  end;

implementation

function TTipoCulturaRepository.ObterPorId(PIdTipoCultura: Integer): TTipoCultura;
var
  LQuery: TFDQuery;
  LConnection: TFDConnection;
begin
  Result := nil;
  LQuery := nil;
  LConnection := nil;
  try
    try
      LConnection := CriarConexao(TDBStart.NomeDatabase);
      LQuery := TFDQuery.Create(nil);
      LQuery.Connection := LConnection;
      LQuery.SQL.Text := Format('SELECT * FROM %s.tipocultura '
                         + 'WHERE id_tipocultura = :PIdTipoCultura', [TDBStart.NomeSchema]);

      LQuery.ParamByName('PIdTipoCultura').AsInteger := PIdTipoCultura;
      LQuery.Open;

      if not LQuery.IsEmpty then
      begin
        Result := TTipoCultura.Create;
        Result.IdTipoCultura := LQuery.FieldByName('id_tipocultura').AsInteger;
        Result.Descricao := LQuery.FieldByName('descricao').AsString;
      end;
    except
      on E:Exception do
        raise Exception.Create(Format('Erro ao buscar registro por id na tabela %s.tipocultura', [TDBStart.NomeSchema])
                              + sLineBreak + sLineBreak + E.ToString);
    end;
  finally
    LQuery.Free;
    LConnection.Free;
  end;
end;

procedure TTipoCulturaRepository.Inserir(PTipoCultura: TTipoCultura);
var
  LQuery: TFDQuery;
  LConnection: TFDConnection;
begin
  LQuery := nil;
  LConnection := nil;
  try
    try
      LConnection := CriarConexao(TDBStart.NomeDatabase);
      LQuery := TFDQuery.Create(nil);
      LQuery.Connection := LConnection;
      LQuery.SQL.Text := Format('INSERT INTO %s.tipocultura (descricao) ' +
                         'VALUES (:PDescricao)', [TDBStart.NomeSchema]);

      LQuery.ParamByName('PDescricao').AsString := PTipoCultura.Descricao;
      LQuery.ExecSQL;
    except
      on E:Exception do
        raise Exception.Create(Format('Erro ao inserir dados na tabela %s.tipocultura', [TDBStart.NomeSchema])
                              + sLineBreak + sLineBreak + E.ToString);
    end;
  finally
    LQuery.Free;
    LConnection.Free;
  end;
end;

function TTipoCulturaRepository.Listar(POrdenacao: string): TObjectList<TTipoCultura>;
var
  LQuery: TFDQuery;
  LConnection: TFDConnection;
  LTipo: TTipoCultura;
begin
  Result := TObjectList<TTipoCultura>.Create(True);
  LQuery := nil;
  LConnection := nil;
  try
    try
      LConnection := CriarConexao(TDBStart.NomeDatabase);
      LQuery := TFDQuery.Create(nil);
      LQuery.Connection := LConnection;
      LQuery.SQL.Text := Format('SELECT * FROM %s.tipocultura '
                        + 'ORDER BY &POrdenacao', [TDBStart.NomeSchema]);
      LQuery.MacroByName('POrdenacao').AsRaw := POrdenacao;
      LQuery.Open;

      while not LQuery.Eof do
      begin
        LTipo := TTipoCultura.Create;
        LTipo.IdTipoCultura := LQuery.FieldByName('id_tipocultura').AsInteger;
        LTipo.Descricao := LQuery.FieldByName('descricao').AsString;
        Result.Add(LTipo);
        LQuery.Next;
      end;
    except
      on E:Exception do
        raise Exception.Create(Format('Erro ao listar dados da tabela %s.tipocultura', [TDBStart.NomeSchema])
                              + sLineBreak + sLineBreak + E.ToString);
    end;
  finally
    LQuery.Free;
    LConnection.Free;
  end;
end;

function TTipoCulturaRepository.ListarCulturasVinculadas(PId_TipoCultura: Integer): TObjectList<TCultura>;
var
  LQuery: TFDQuery;
  LConnection: TFDConnection;
  LCultura: TCultura;
begin
  Result := TObjectList<TCultura>.Create(True);
  LQuery := nil;
  LConnection := nil;
  try
    try
      LConnection := CriarConexao(TDBStart.NomeDatabase);
      LQuery := TFDQuery.Create(nil);
      LQuery.Connection := LConnection;
      LQuery.SQL.Text :=
      Format('SELECT id_cultura, nome from ' +
            '%s.cultura ' +
            'WHERE id_tipocultura = :PIdTipoCultura ' +
            'ORDER BY id_cultura',
        [TDBStart.NomeSchema]);

      LQuery.ParamByName('PIdTipoCultura').AsInteger := PId_TipoCultura;
      LQuery.Open;

      while not LQuery.Eof do
      begin
        LCultura := TCultura.Create;

        LCultura.IdCultura := LQuery.FieldByName('id_cultura').AsInteger;
        LCultura.Nome := LQuery.FieldByName('nome').AsString;
        Result.Add(LCultura);
        LQuery.Next;
      end;
    except
      on E:Exception do
        raise Exception.Create(Format('Erro ao listar culturas vinculadas na tabela %s.cultura', [TDBStart.NomeSchema])
                              + sLineBreak + sLineBreak + E.ToString);
    end;
  finally
    LQuery.Free;
    LConnection.Free;
  end;
end;

function TTipoCulturaRepository.Pesquisar(PBusca, PORdenacao: string): TObjectList<TTipoCultura>;
var
  LQuery: TFDQuery;
  LConnection: TFDConnection;
  LTipo: TTipoCultura;
begin
  Result := TObjectList<TTipoCultura>.Create(True);
  LQuery := nil;
  LConnection := nil;
  try
    try
      LConnection := CriarConexao(TDBStart.NomeDatabase);
      LQuery := TFDQuery.Create(nil);
      LQuery.Connection := LConnection;
      LQuery.SQL.Text := Format('SELECT * FROM %0:s.tipocultura '
                        + 'WHERE CAST(id_tipocultura AS text) ilike CAST(:PIdTipoCultura AS text) or '
                        + '%0:s.sem_acento(descricao::text) ilike %0:s.sem_acento(:PDescricao::text)'
                        + 'ORDER BY &POrdenacao',
                        [TDBStart.NomeSchema]);
      LQuery.ParamByName('PIdTipoCultura').AsString := '%' + PBusca + '%';
      LQuery.ParamByName('PDescricao').AsString := '%' + PBusca + '%';
      LQuery.MacroByName('POrdenacao').AsRaw := PORdenacao;
      LQuery.Open;

      while not LQuery.Eof do
      begin
        LTipo := TTipoCultura.Create;
        LTipo.IdTipoCultura := LQuery.FieldByName('id_tipocultura').AsInteger;
        LTipo.Descricao := LQuery.FieldByName('descricao').AsString;
        LTipo.UtilizaUnidade := LQuery.FieldByName('utiliza_unidade').AsBoolean;
        Result.Add(LTipo);
        LQuery.Next;
      end;
    except
      on E:Exception do
        raise Exception.Create(Format('Erro ao pesquisar dados da tabela %s.tipocultura', [TDBStart.NomeSchema])
                              + sLineBreak + sLineBreak + E.ToString);
    end;
  finally
    LQuery.Free;
    LConnection.Free;
  end;
end;

procedure TTipoCulturaRepository.Atualizar(PTipoCultura: TTipoCultura);
var
  LQuery: TFDQuery;
  LConnection: TFDConnection;
begin
  LQuery := nil;
  LConnection := nil;
  try
    try
      LConnection := CriarConexao(TDBStart.NomeDatabase);
      LQuery := TFDQuery.Create(nil);
      LQuery.Connection := LConnection;
      LQuery.SQL.Text := Format('UPDATE %s.tipocultura '
                         + 'SET descricao = :PDescricao '
                         + 'WHERE id_tipocultura = :PIdTipoCultura', [TDBStart.NomeSchema]);

      LQuery.ParamByName('PDescricao').AsString := PTipoCultura.Descricao;
      LQuery.ParamByName('PIdTipoCultura').AsInteger := PTipoCultura.IdTipoCultura;
      LQuery.ExecSQL;
    except
      on E:Exception do
        raise Exception.Create(Format('Erro ao editar dados na tabela %s.tipocultura', [TDBStart.NomeSchema])
                              + sLineBreak + sLineBreak + E.ToString);
    end;
  finally
    LQuery.Free;
    LConnection.Free;
  end;
end;

