{ TFrmRelatorioTipoCultura }

procedure TFrmRelatorioCultura.CarregarRelatorio(PBusca, POrdenacao: string);
var
  LDFMTableCultura: TFDMemTable;
  LDsCultura: TDataSource;
  LLista: TObjectList<TCultura>;
  I: Integer;
  LPreviewSetup: TRLPreviewSetup;
begin
  LLista := nil;
  LDFMTableCultura := nil;
  LDsCultura := nil;
  LPreviewSetup := nil;

  try
    try
      LDFMTableCultura := TFDMemTable.Create(nil);
      LDFMTableCultura.FieldDefs.Add('id_cultura', ftInteger);
      LDFMTableCultura.FieldDefs.Add('nome', ftString, 50, True);
      LDFMTableCultura.FieldDefs.Add('descricao_tipo', ftString, 50, True);
      LDFMTableCultura.FieldDefs.Add('data_plantio', ftDateTime);
      LDFMTableCultura.FieldDefs.Add('ativo', ftString, 3, True);
      LDFMTableCultura.FieldDefs.Add('foto', ftBlob);
      LDFMTableCultura.CreateDataSet;

      LDsCultura := TDataSource.Create(nil);
      LDsCultura.DataSet := LDFMTableCultura;

      LLista := FCulturaController.Pesquisar(PBusca, POrdenacao);

      for I := 0 to LLista.Count -1 do
      begin
        LDFMTableCultura.Append;
        LDFMTableCultura.FieldByName('id_cultura').AsInteger := LLista[i].IdCultura;
        LDFMTableCultura.FieldByName('nome').AsString := LLista[i].Nome;
        LDFMTableCultura.FieldByName('descricao_tipo').AsString := LLista[i].DescricaoTipoCultura;
        LDFMTableCultura.FieldByName('data_plantio').AsDateTime := LLista[i].DataPlantio;
        LDFMTableCultura.FieldByName('ativo').AsString := BoolToSimNao(LLista[i].Ativo);

        var LFotoTemp := FCulturaController.ObterPorId(LLista[i].IdCultura);
        try
          LFotoTemp.Foto.Position := 0;
          if Assigned(LFotoTemp.Foto) and (LFotoTemp.Foto.Size > 0) then
            TBlobField(LDFMTableCultura.FieldByName('foto')).LoadFromStream(LFotoTemp.Foto)
         else
          begin
            LBitmapTemp := DmIcons.ImgCltIcons.GetBitmap(13, DbImageFoto.Width, DbImageFoto.Height);
            if Assigned(LBitmapTemp) then
            try
              var LStreamPadrao := TMemoryStream.Create;
              try
                LBitmapTemp.SaveToStream(LStreamPadrao);
                LStreamPadrao.Position := 0;
                TBlobField(LDFMTableCultura.FieldByName('foto')).LoadFromStream(LStreamPadrao);
              finally
                LStreamPadrao.Free;
              end;
            finally
              LBitmapTemp.Free;
            end;
          end;
        finally
          LFotoTemp.Free;
        end;
          //TBlobField(LDFMTableCultura.FieldByName('foto')).LoadFromStream(LFoto);
        LDFMTableCultura.Post;
      end;

      RlrMaster.DataSource := LDsCultura;
      DbTextIdentificador.DataSource := LDsCultura;
      DbTextDescricao.DataSource := LDsCultura;
      DbTextTipo.DataSource := LDsCultura;
      DbTextDataPlantio.DataSource := LDsCultura;
      DbTextAtivo.DataSource := LDsCultura;
      DbImageFoto.DataSource := LDsCultura;

      DbTextIdentificador.DataField := 'id_cultura';
      DbTextDescricao.DataField := 'nome';
      DbTextTipo.DataField := 'descricao_tipo';
      DbTextDataPlantio.DataField := 'data_plantio';
      DbTextAtivo.DataField := 'ativo';
      DbImageFoto.DataField := 'foto';

      LPreviewSetup := TRLPreviewSetup.Create(nil);
      LPreviewSetup.ZoomFactor := 85;
      RlrMaster.Preview();
    except
      on E: Exception do
        raise Exception.Create('Erro ao carregar o relat躁io.' + sLineBreak + sLineBreak + E.ToString);
    end;
  finally
    LLista.Free;
    LDsCultura.Free;
    LDFMTableCultura.Free;
    LPreviewSetup.Free;
  end;
end;

constructor TFrmRelatorioCultura.Create(POwner: TComponent; PCulturaController: TCulturaController);
begin
  inherited Create(POwner);
  FCulturaController := PCulturaController;
end;

destructor TFrmRelatorioCultura.Destroy;
begin
  FCulturaController.Free;
  inherited;
end;

