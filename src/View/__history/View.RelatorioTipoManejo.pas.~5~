{$R *.dfm}

{ TFrmRelatorioTipoCultura }

procedure TFrmRelatorioTipoManejo.CarregarRelatorio(PBusca, POrdenacao: string);
var
  LDFMTableTipoCultura: TFDMemTable;
  LDsTipoManejo: TDataSource;
  LLista: TObjectList<TTipoCultura>;
  I: Integer;
  LPreviewSetup: TRLPreviewSetup;
begin
  LLista := nil;
  LDFMTableTipoCultura := nil;
  LDsTipoManejo := nil;
  LPreviewSetup := nil;

  try
    try
      LDFMTableTipoCultura := TFDMemTable.Create(nil);
      LDFMTableTipoCultura.FieldDefs.Add('id_tipocultura', ftInteger);
      LDFMTableTipoCultura.FieldDefs.Add('descricao', ftString, 50, True);
      LDFMTableTipoCultura.CreateDataSet;

      LDsTipoManejo := TDataSource.Create(nil);
      LDsTipoManejo.DataSet := LDFMTableTipoCultura;

      LLista := FTipoCulturaController.Pesquisar(PBusca, POrdenacao);

      for I := 0 to LLista.Count -1 do
      begin
        LDFMTableTipoCultura.Append;
        LDFMTableTipoCultura.FieldByName('id_tipocultura').AsInteger := LLista[i].IdTipoCultura;
        LDFMTableTipoCultura.FieldByName('descricao').AsString := LLista[i].Descricao;
        LDFMTableTipoCultura.Post;
      end;

      RlrMaster.DataSource := LDsTipoManejo;
      DbTextIdentificador.DataSource := LDsTipoManejo;
      DbTextDescricao.DataSource := LDsTipoManejo;

      DbTextIdentificador.DataField := 'id_tipocultura';
      DbTextDescricao.DataField := 'descricao';

      LPreviewSetup := TRLPreviewSetup.Create(nil);
      LPreviewSetup.ZoomFactor := 85;
      RlrMaster.Preview();
    except
      on E: Exception do
        raise Exception.Create('Erro ao carregar o relat躁io.' + sLineBreak + sLineBreak + E.ToString);
    end;
  finally
    LLista.Free;
    LDsTipoManejo.Free;
    LDFMTableTipoCultura.Free;
    LPreviewSetup.Free;
  end;
end;

constructor TFrmRelatorioTipoManejo.Create(POwner: TComponent; PTipoCulturaController: TTipoCulturaController);
begin
  inherited Create(POwner);
  FTipoCulturaController := PTipoCulturaController;
end;

destructor TFrmRelatorioTipoManejo.Destroy;
begin
  FTipoCulturaController.Free;
  inherited;
end;

end.
