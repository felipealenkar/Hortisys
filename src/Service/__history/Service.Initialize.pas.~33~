unit Service.Initialize;

interface

uses
  Model.ParametrosDb,
  Repository.Initialize,
  Winapi.Windows,
  System.SysUtils,
  FireDAC.Comp.Client;
type
  TAppStarter = class
  private
    FDatabaseInitialize: TDatabaseInitialize;
    procedure InstalarBancoDeDados;
  public
    constructor Create(PConnection: TFDConnection);
    destructor Destroy; override;
    function PrepararAmbiente: Boolean;

  end;


implementation

{ TAppStarter }

function TAppStarter.PrepararAmbiente: Boolean;
var
  BancoExiste: Boolean;
begin
  try
    Result := True;
    if FDatabaseInitialize.Conectar('postgres') then
    begin
      BancoExiste := FDatabaseInitialize.ExistirBancoDeDados;
      if not BancoExiste then
        MessageBox(0, PChar('!!!Bem vindo ao HortiSys!!!, ' + sLineBreak + sLineBreak +
                    'N„o foi encontrado o database ' + TParametrosDb.NomeDatabase + ', ele ser· criado.'),
                    'HortiSys', MB_OK or MB_ICONINFORMATION or MB_TASKMODAL);
        InstalarBancoDeDados;
        if not BancoExiste then
          MessageBox(0, PChar('Banco de dados ' + TParametrosDb.NomeDatabase + ' criado com sucesso'),
                    'HortiSys', MB_OK or MB_ICONINFORMATION or MB_TASKMODAL);
    end;
  except
    on E:Exception do
    begin
      Result := False;
      MessageBox(0, PChar(E.Message), 'HortiSys', MB_OK or MB_ICONERROR or MB_TASKMODAL);
    end;
  end;
end;

constructor TAppStarter.Create(PConnection: TFDConnection);
begin
  FDatabaseInitialize := TDatabaseInitialize.Create(PConnection);
end;

destructor TAppStarter.Destroy;
begin
  FDatabaseInitialize.Free;
  inherited;
end;

procedure TAppStarter.InstalarBancoDeDados;
begin
  try
    FDatabaseInitialize.CriarDatabase;
    FDatabaseInitialize.Conectar(TParametrosDb.NomeDatabase);
    FDatabaseInitialize.CriarSchema;
    FDatabaseInitialize.CriarTabelaTipoCultura;
    FDatabaseInitialize.CriarTabelaCultura;
    FDatabaseInitialize.CriarTabelaManejo;
  except
    on E:Exception do
      raise Exception.Create('Erro no processo de CriaÁ„o do banco de dados' +
            sLineBreak + sLineBreak + E.Message + sLineBreak + sLineBreak +
                            'A aplicaÁ„o n„o ser· inicializada.');
  end;
end;

end.
